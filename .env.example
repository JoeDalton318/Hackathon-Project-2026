# ============================================
# FICHIER .env.example - TEMPLATE PROJET
# ============================================
# 1. Copier ce fichier vers .env
# 2. Demander les vrais credentials à Samuel (Lead Backend)
# 3. Remplir les valeurs entre < >
# NE JAMAIS COMMITTER LE FICHIER .env
# ============================================

# ============================================
# MONGODB ATLAS (Cloud Database)
# ============================================
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=hackaton
MONGO_DB=hackathon
MONGO_DATABASE=hackathon
MONGO_PASSWORD=<password>

# ============================================
# MINIO (Data Lake S3-compatible)
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET=datalake
MINIO_RAW_PREFIX=raw/
MINIO_CLEAN_PREFIX=clean/
MINIO_CURATED_PREFIX=curated/

# ============================================
# AIRFLOW (Orchestration)
# ============================================
AIRFLOW_URL=http://localhost:8080
AIRFLOW_DAG_ID=doc_pipeline
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_DB_URL=postgresql+psycopg2://airflow_user:airflow_pass@localhost:5432/airflow_db

# ============================================
# BACKEND API (FastAPI)
# ============================================
BACKEND_API_URL=http://localhost:8000
API_TIMEOUT=10
INTERNAL_API_SECRET=your_secret_key_here
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# JWT Authentication
JWT_SECRET_KEY=<your-jwt-secret-key>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ============================================
# INSEE API (Données entreprises françaises)
# ============================================
INSEE_BASE_URL=https://api.insee.fr/api-sirene/3.11
INSEE_API_KEY=<your-insee-api-key>

# ============================================
# REDIS (Message Broker)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# ENVIRONNEMENT
# ============================================
ENVIRONMENT=development
DEBUG=True
