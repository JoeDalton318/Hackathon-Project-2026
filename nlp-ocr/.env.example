# Copier en .env et adapter

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here
MINIO_ROOT_USER=your_root_user_here
MINIO_ROOT_PASSWORD=your_root_password_here
MINIO_SECURE=false

# MongoDB
MONGO_ROOT_USER=your_mongo_user_here
MONGO_ROOT_PASSWORD=your_mongo_password_here
MONGO_URI=mongodb://user:password@host-distant:27017/ocr_extraction
MONGO_DB=ocr_extraction

# API
LOG_LEVEL=INFO

# OCR
FORCE_EASYOCR=0
TESSERACT_CMD=
OCR_FALLBACK_THRESHOLD=0.65
